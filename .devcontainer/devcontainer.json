{
    "name": "Claude Code Sandbox",
    "build": {
        "dockerfile": "../Dockerfile",
        "context": "..",
        "args": {
            "CLAUDE_CODE_VERSION": "latest"
        }
    },
    "remoteUser": "node",
    "capAdd": [
        "NET_ADMIN",
        "NET_RAW"
    ],
    "remoteEnv": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "DEVCONTAINER": "true"
    },
    "mounts": [
        "source=claude-devcontainer-config,target=/home/node/.claude,type=volume"
    ],
    "workspaceMount": "source=${localWorkspaceFolder}/shared,target=/workspace,type=bind,consistency=delegated",
    "workspaceFolder": "/workspace",
    "postStartCommand": "sudo /usr/local/bin/init-firewall.sh",
    "waitFor": "postStartCommand",
    "customizations": {
        "vscode": {
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash"
            },
            "extensions": [
                "anthropic.claude-code"
            ]
        }
    }
}
